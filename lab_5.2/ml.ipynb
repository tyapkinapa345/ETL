 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🚀 ML-классификация ракет (CLIP Model)\n",
    "## Вариант 16: Rocket Launch Analytics\n",
    "\n",
    "Этот ноутбук использует предобученную модель CLIP для классификации изображений ракет.\n",
    "\n",
    "**Вход:** Изображения из папки `data/images/`\n",
    "\n",
    "**Выход:** Файл `data/ml_predictions.csv` с предсказаниями"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Импорт библиотек"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import pandas as pd\n",
    "import torch\n",
    "from PIL import Image\n",
    "from transformers import CLIPProcessor, CLIPModel\n",
    "from datetime import datetime\n",
    "import warnings\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "print(\"✅ Библиотеки импортированы\")\n",
    "print(f\"PyTorch version: {torch.__version__}\")\n",
    "print(f\"CUDA available: {torch.cuda.is_available()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Настройка путей и параметров"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Пути к данным\n",
    "IMAGES_DIR = \"data/images\"\n",
    "OUTPUT_FILE = \"data/ml_predictions.csv\"\n",
    "\n",
    "# Модель CLIP\n",
    "MODEL_NAME = \"openai/clip-vit-base-patch32\"\n",
    "\n",
    "# Классы для классификации (типы ракет)\n",
    "ROCKET_LABELS = [\n",
    "    \"Falcon 9 rocket\",\n",
    "    \"Falcon Heavy rocket\",\n",
    "    \"Soyuz rocket\",\n",
    "    \"Ariane 5 rocket\",\n",
    "    \"Ariane 6 rocket\",\n",
    "    \"Electron rocket\",\n",
    "    \"Long March rocket\",\n",
    "    \"Atlas V rocket\",\n",
    "    \"Delta IV rocket\",\n",
    "    \"Antares rocket\",\n",
    "    \"Vulcan rocket\",\n",
    "    \"New Glenn rocket\",\n",
    "    \"Starship rocket\",\n",
    "    \"Space Shuttle\",\n",
    "    \"launch vehicle\",\n",
    "    \"spacecraft\"\n",
    "]\n",
    "\n",
    "print(f\"📁 Images directory: {IMAGES_DIR}\")\n",
    "print(f\"📄 Output file: {OUTPUT_FILE}\")\n",
    "print(f\"🏷️  Labels: {len(ROCKET_LABELS)} classes\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Загрузка модели CLIP"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"🔄 Загрузка модели CLIP...\")\n",
    "\n",
    "# Загрузка модели и процессора\n",
    "model = CLIPModel.from_pretrained(MODEL_NAME)\n",
    "processor = CLIPProcessor.from_pretrained(MODEL_NAME)\n",
    "\n",
    "# Определение устройства (CPU/GPU)\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "model = model.to(device)\n",
    "\n",
    "print(f\"✅ Модель загружена на устройстве: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Функция классификации изображения"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def classify_image(image_path, model, processor, labels, device):\n",
    "    \"\"\"\n",
    "    Классифицировать изображение с помощью CLIP\n",
    "    \n",
    "    Args:\n",
    "        image_path: Путь к изображению\n",
    "        model: CLIP модель\n",
    "        processor: CLIP процессор\n",
    "        labels: Список текстовых меток\n",
    "        device: Устройство (CPU/GPU)\n",
    "    \n",
    "    Returns:\n",
    "        dict с результатами классификации\n",
    "    \"\"\"\n",
    "    result = {\n",
    "        \"image_name\": os.path.basename(image_path),\n",
    "        \"image_path\": image_path,\n",
    "        \"predicted_rocket\": None,\n",
    "        \"confidence\": 0.0,\n",
    "        \"top_3_predictions\": [],\n",
    "        \"error\": None,\n",
    "        \"processed_at\": datetime.now().isoformat()\n",
    "    }\n",
    "    \n",
    "    try:\n",
    "        # Загрузка изображения\n",
    "        image = Image.open(image_path).convert(\"RGB\")\n",
    "        \n",
    "        # Подготовка входных данных\n",
    "        inputs = processor(\n",
    "            text=labels,\n",
    "            images=image,\n",
    "            return_tensors=\"pt\",\n",
    "            padding=True\n",
    "        ).to(device)\n",
    "        \n",
    "        # Получение предсказаний\n",
    "        with torch.no_grad():\n",
    "            outputs = model(**inputs)\n",
    "            logits_per_image = outputs.logits_per_image\n",
    "            probs = logits_per_image.softmax(dim=1)\n",
    "        \n",
    "        # Получение топ-3 предсказаний\n",
    "        top_probs, top_indices = probs[0].topk(3)\n",
    "        \n",
    "        # Основное предсказание\n",
    "        top_idx = top_indices[0].item()\n",
    "        result[\"predicted_rocket\"] = labels[top_idx]\n",
    "        result[\"confidence\"] = round(top_probs[0].item() * 100, 2)\n",
    "        \n",
    "        # Топ-3 предсказания\n",
    "        for i in range(3):\n",
    "            result[\"top_3_predictions\"].append({\n",
    "                \"label\": labels[top_indices[i].item()],\n",
    "                \"confidence\": round(top_probs[i].item() * 100, 2)\n",
    "            })\n",
    "        \n",
    "        print(f\"✅ {result['image_name']}: {result['predicted_rocket']} ({result['confidence']}%)\")\n",
    "        \n",
    "    except Exception as e:\n",
    "        result[\"error\"] = str(e)\n",
    "        print(f\"❌ {os.path.basename(image_path)}: Error - {str(e)[:100]}\")\n",
    "    \n",
    "    return result"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Проверка наличия изображений"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Проверка папки с изображениями\n",
    "if not os.path.exists(IMAGES_DIR):\n",
    "    print(f\"❌ Папка {IMAGES_DIR} не найдена!\")\n",
    "    print(\"💡 Запустите DAG в Airflow для скачивания изображений\")\n",
    "    raise FileNotFoundError(f\"Directory {IMAGES_DIR} not found\")\n",
    "\n",
    "# Получение списка изображений\n",
    "image_files = [\n",
    "    os.path.join(IMAGES_DIR, f) \n",
    "    for f in os.listdir(IMAGES_DIR) \n",
    "    if f.lower().endswith(('.jpg', '.jpeg', '.png', '.webp'))\n",
    "]\n",
    "\n",
    "print(f\"📊 Найдено изображений: {len(image_files)}\")\n",
    "\n",
    "if len(image_files) == 0:\n",
    "    print(\"⚠️ Нет изображений для обработки!\")\n",
    "    print(\"💡 Запустите DAG `listing_TyapkinaPA_Rocket` в Airflow\")\n",
    "    raise ValueError(\"No images found in directory\")\n",
    "\n",
    "# Показать первые 5 файлов\n",
    "print(\"\\n📁 Первые изображения:\")\n",
    "for img in image_files[:5]:\n",
    "    print(f\"   - {os.path.basename(img)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Запуск классификации всех изображений"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"🚀 Запуск классификации изображений...\\n\")\n",
    "\n",
    "# Результаты классификации\n",
    "results = []\n",
    "\n",
    "# Обработка каждого изображения\n",
    "for idx, img_path in enumerate(image_files, 1):\n",
    "    print(f\"[{idx}/{len(image_files)}] \", end=\"\")\n",
    "    result = classify_image(img_path, model, processor, ROCKET_LABELS, device)\n",
    "    results.append(result)\n",
    "\n",
    "print(f\"\\n✅ Обработано {len(results)} изображений\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Создание DataFrame и статистика"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Создание DataFrame\n",
    "df = pd.DataFrame(results)\n",
    "\n",
    # Упрощение колонки top_3_predictions для CSV\n",
    "df[\"top_3_predictions\"] = df[\"top_3_predictions\"].apply(\n",
    "    lambda x: str(x) if x else \"[]\"\n",
    ")\n",
    "\n",
    "# Статистика\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"📊 СТАТИСТИКА КЛАССИФИКАЦИИ\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Всего изображений: {len(df)}\")\n",
    "print(f\"Успешно обработано: {len(df[df['error'].isna()])}\")\n",
    "print(f\"С ошибками: {len(df[df['error'].notna()])}\")\n",
    "\n",
    "if len(df[df['error'].isna()]) > 0:\n",
    "    print(f\"\\nСредняя уверенность: {df[df['error'].isna()]['confidence'].mean():.2f}%\")\n",
    "    print(f\"Минимальная уверенность: {df[df['error'].isna()]['confidence'].min():.2f}%\")\n",
    "    print(f\"Максимальная уверенность: {df[df['error'].isna()]['confidence'].max():.2f}%\")\n",
    "    \n",
    "    print(\"\\n🏷️  Распределение по типам ракет:\")\n",
    "    print(df[df['error'].isna()]['predicted_rocket'].value_counts())\n",
    "\n",
    "print(\"=\"*60)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Сохранение результатов в CSV"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Создание директории если не существует\n",
    "os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)\n",
    "\n",
    "# Сохранение в CSV\n",
    "df.to_csv(OUTPUT_FILE, index=False, encoding='utf-8')\n",
    "\n",
    "print(f\"\\n✅ Результаты сохранены в: {OUTPUT_FILE}\")\n",
    "print(f\"📄 Размер файла: {os.path.getsize(OUTPUT_FILE)} bytes\")\n",
    "\n",
    "# Предпросмотр\n",
    "print(\"\\n📋 Первые 5 строк результата:\")\n",
    "display(df[['image_name', 'predicted_rocket', 'confidence']].head())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Визуализация результатов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Фильтрация успешных предсказаний\n",
    "df_success = df[df['error'].isna()]\n",
    "\n",
    "if len(df_success) > 0:\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "    \n",
    "    # График 1: Распределение по типам ракет\n",
    "    ax1 = axes[0]\n",
    "    rocket_counts = df_success['predicted_rocket'].value_counts()\n",
    "    rocket_counts.plot(kind='barh', ax=ax1, color='steelblue')\n",
    "    ax1.set_title('📊 Распределение по типам ракет', fontsize=14, fontweight='bold')\n",
    "    ax1.set_xlabel('Количество')\n",
    "    ax1.invert_yaxis()\n",
    "    \n",
    "    # График 2: Распределение уверенности\n",
    "    ax2 = axes[1]\n",
    "    ax2.hist(df_success['confidence'], bins=10, color='coral', edgecolor='black')\n",
    "    ax2.set_title('📈 Распределение уверенности модели', fontsize=14, fontweight='bold')\n",
    "    ax2.set_xlabel('Уверенность (%)')\n",
    "    ax2.set_ylabel('Количество изображений')\n",
    "    ax2.axvline(df_success['confidence'].mean(), color='red', linestyle='--', \n",
    "                label=f'Среднее: {df_success[\"confidence\"].mean():.1f}%')\n",
    "    ax2.legend()\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('data/classification_results.png', dpi=150, bbox_inches='tight')\n",
    "    print(\"✅ График сохранён: data/classification_results.png\")\n",
    "    plt.show()\n",
    "else:\n",
    "    print(\"⚠️ Нет успешных предсказаний для визуализации\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Галерея предсказаний"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Показ первых 9 изображений с предсказаниями\n",
    "if len(df_success) > 0:\n",
    "    fig, axes = plt.subplots(3, 3, figsize=(15, 15))\n",
    "    axes = axes.flatten()\n",
    "    \n",
    "    for idx, (_, row) in enumerate(df_success.head(9).iterrows()):\n",
    "        try:\n",
    "            img = Image.open(row['image_path'])\n",
    "            axes[idx].imshow(img)\n",
    "            axes[idx].set_title(f\"{row['predicted_rocket']}\\n{row['confidence']}%\", \n",
    "                               fontsize=12, fontweight='bold')\n",
    "            axes[idx].axis('off')\n",
    "        except Exception as e:\n",
    "            axes[idx].text(0.5, 0.5, f'Error\\n{str(e)[:50]}', \n",
    "                          ha='center', va='center', fontsize=10)\n",
    "            axes[idx].axis('off')\n",
    "    \n",
    "    # Скрыть пустые подграфики\n",
    "    for idx in range(len(df_success.head(9)), 9):\n",
    "        axes[idx].axis('off')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('data/predictions_gallery.png', dpi=150, bbox_inches='tight')\n",
    "    print(\"✅ Галерея сохранена: data/predictions_gallery.png\")\n",
    "    plt.show()\n",
    "else:\n",
    "    print(\"⚠️ Нет изображений для галереи\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Финальный отчёт"
   ]
  },
  {
   "cell_type": "code",
