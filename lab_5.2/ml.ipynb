   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"🎯 ИТОГОВЫЙ ОТЧЁТ ML-КЛАССИФИКАЦИИ\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Дата выполнения: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "print(f\"Модель: {MODEL_NAME}\")\n",
    "print(f\"Устройство: {device}\")\n",
    "print(f\"Классов для классификации: {len(ROCKET_LABELS)}\")\n",
    "print(\"-\"*60)\n",
    "print(f\"Всего изображений: {len(df)}\")\n",
    "print(f\"Успешно: {len(df_success)} ({len(df_success)/len(df)*100:.1f}%)\")\n",
    "print(f\"С ошибками: {len(df) - len(df_success)}\")\n",
    "if len(df_success) > 0:\n",
    "    print(f\"Средняя уверенность: {df_success['confidence'].mean():.2f}%\")\n",
    "print(\"-\"*60)\n",
    "print(f\"Выходной файл: {OUTPUT_FILE}\")\n",
    "print(f\"Размер файла: {os.path.getsize(OUTPUT_FILE)} bytes\")\n",
    "print(\"=\"*60)\n",
    "print(\"✅ ML-классификация завершена успешно!\")\n",
    "print(\"💡 Теперь обновите страницу Streamlit для просмотра результатов\")\n",
    "print(\"=\"*60)"
   ]
  }
