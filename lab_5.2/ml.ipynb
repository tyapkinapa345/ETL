{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🚀 ML-классификация ракет (CLIP Model)\n",
    "## Вариант 16: Rocket Launch Analytics\n",
    "\n",
    "**Важно:** Перед запуском убедитесь, что DAG `listing_TyapkinaPA_Rocket` успешно выполнен и в папке `data/images/` есть изображения."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import pandas as pd\n",
    "import torch\n",
    "from PIL import Image\n",
    "from transformers import CLIPProcessor, CLIPModel\n",
    "from datetime import datetime\n",
    "import warnings\n",
    "import logging\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\n",
    "logger = logging.getLogger(__name__)\n",
    "\n",
    "print(\"✅ Библиотеки импортированы\")\n",
    "print(f\"PyTorch version: {torch.__version__}\")\n",
    "print(f\"CUDA available: {torch.cuda.is_available()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Настройка путей (автоматическое определение)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Определяем корневую директорию проекта\n",
    "if os.path.exists('/opt/airflow'):\n",
    "    BASE_DIR = '/opt/airflow'\n",
    "else:\n",
    "    BASE_DIR = os.getcwd()\n",
    "\n",
    "IMAGES_DIR = os.path.join(BASE_DIR, 'data', 'images')\n",
    "OUTPUT_FILE = os.path.join(BASE_DIR, 'data', 'ml_predictions.csv')\n",
    "\n",
    "print(f\"📁 Базовая директория: {BASE_DIR}\")\n",
    "print(f\"🖼️  Изображения: {IMAGES_DIR}\")\n",
    "print(f\"📄 Выходной файл: {OUTPUT_FILE}\")\n",
    "\n",
    "# Создаём папку, если её нет\n",
    "os.makedirs(IMAGES_DIR, exist_ok=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Проверка наличия изображений"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Получаем список изображений\n",
    "image_files = [\n",
    "    os.path.join(IMAGES_DIR, f) \n",
    "    for f in os.listdir(IMAGES_DIR) \n",
    "    if f.lower().endswith(('.jpg', '.jpeg', '.png', '.webp'))\n",
    "]\n",
    "\n",
    "print(f\"📊 Найдено изображений: {len(image_files)}\")\n",
    "\n",
    "if len(image_files) == 0:\n",
    "    print(\"\\n⚠️ НЕТ ИЗОБРАЖЕНИЙ!\\n\")\n",
    "    print(\"Убедитесь, что:\")\n",
    "    print(\"1. DAG listing_TyapkinaPA_Rocket успешно выполнен.\")\n",
    "    print(\"2. В папке data/images/ есть файлы.\")\n",
    "    print(\"3. Запустите DAG заново и дождитесь его завершения.\")\n",
    "    raise SystemExit(\"Нет изображений для классификации.\")\n",
    "\n",
    "# Покажем первые 5\n",
    "print(\"\\n📁 Первые изображения:\")\n",
    "for img in image_files[:5]:\n",
    "    print(f\"   - {os.path.basename(img)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Загрузка модели CLIP (один раз)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "MODEL_NAME = \"openai/clip-vit-base-patch32\"\n",
    "ROCKET_LABELS = [\n",
    "    \"Falcon 9 rocket\", \"Falcon Heavy rocket\", \"Soyuz rocket\",\n",
    "    \"Ariane 5 rocket\", \"Electron rocket\", \"Long March rocket\",\n",
    "    \"Atlas V rocket\", \"Delta IV rocket\", \"Antares rocket\",\n",
    "    \"Starship rocket\", \"Space Shuttle\", \"launch vehicle\"\n",
    "]\n",
    "\n",
    "print(\"🔄 Загрузка модели CLIP (может занять 1-2 минуты при первом запуске)...\")\n",
    "try:\n",
    "    model = CLIPModel.from_pretrained(MODEL_NAME)\n",
    "    processor = CLIPProcessor.from_pretrained(MODEL_NAME)\n",
    "    device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "    model = model.to(device)\n",
    "    print(f\"✅ Модель загружена на устройстве: {device}\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Ошибка загрузки модели: {e}\")\n",
    "    raise"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Функция классификации"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def classify_image(image_path):\n",
    "    try:\n",
    "        image = Image.open(image_path).convert(\"RGB\")\n",
    "        inputs = processor(text=ROCKET_LABELS, images=image, return_tensors=\"pt\", padding=True).to(device)\n",
    "        with torch.no_grad():\n",
    "            outputs = model(**inputs)\n",
    "            probs = outputs.logits_per_image.softmax(dim=1)[0]\n",
    "        top_prob, top_idx = probs.max(dim=0)\n",
    "        return {\n",
    "            \"image_name\": os.path.basename(image_path),\n",
    "            \"predicted_rocket\": ROCKET_LABELS[top_idx.item()],\n",
    "            \"confidence\": round(top_prob.item() * 100, 2),\n",
    "            \"error\": None\n",
    "        }\n",
    "    except Exception as e:\n",
    "        return {\n",
    "            \"image_name\": os.path.basename(image_path),\n",
    "            \"predicted_rocket\": None,\n",
    "            \"confidence\": 0.0,\n",
    "            \"error\": str(e)\n",
    "        }"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Запуск классификации"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = []\n",
    "print(\"🚀 Запуск классификации...\\n\")\n",
    "for idx, img_path in enumerate(image_files, 1):\n",
    "    print(f\"[{idx}/{len(image_files)}] Обработка {os.path.basename(img_path)}...\", end=\" \")\n",
    "    res = classify_image(img_path)\n",
    "    results.append(res)\n",
    "    if res[\"error\"]:\n",
    "        print(f\"❌ Ошибка: {res['error']}\")\n",
    "    else:\n",
    "        print(f\"✅ {res['predicted_rocket']} ({res['confidence']}%)\")\n",
    "\n",
    "df = pd.DataFrame(results)\n",
    "print(f\"\\n✅ Обработано {len(df)} изображений\")\n",
    "print(f\"✅ Успешно: {df['error'].isna().sum()}\")\n",
    "print(f\"❌ Ошибок: {df['error'].notna().sum()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Сохранение результатов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.to_csv(OUTPUT_FILE, index=False, encoding='utf-8')\n",
    "print(f\"\\n✅ Результаты сохранены в {OUTPUT_FILE}\")\n",
    "print(f\"📄 Размер файла: {os.path.getsize(OUTPUT_FILE)} байт\")\n",
    "\n",
    "# Покажем первые строки\n",
    "print(\"\\n📋 Первые 5 предсказаний:\")\n",
    "print(df[['image_name', 'predicted_rocket', 'confidence']].head().to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Финальный отчёт"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"🎯 ИТОГОВЫЙ ОТЧЁТ\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Дата: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "print(f\"Модель: {MODEL_NAME}\")\n",
    "print(f\"Изображений: {len(df)}\")\n",
    "print(f\"Успешно: {df['error'].isna().sum()}\")\n",
    "if df['error'].isna().sum() > 0:\n",
    "    print(f\"Средняя уверенность: {df[df['error'].isna()]['confidence'].mean():.2f}%\")\n",
    "print(\"=\"*60)\n",
    "print(\"✅ Готово! Теперь обновите Streamlit (http://localhost:8501)\")\n",
    "print(\"=\"*60)"
   }
  }
 ],
